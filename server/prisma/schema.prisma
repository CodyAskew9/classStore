// ClassCrest — free classroom economy for teachers; premium home economy for parents

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  TEACHER
  STUDENT
  PARENT
}

enum SubscriptionTier {
  FREE           // Teachers and students (school features)
  PREMIUM_PARENT // Paid parent tier — home chores & allowance
}

enum TransactionType {
  JOB_PAYOUT
  BEHAVIOR_BONUS
  STORE_PURCHASE
  TEACHER_ADJUSTMENT
  HOME_CHORE_PAYOUT // Premium parent tier
  HOME_ALLOWANCE    // Premium parent tier
}

enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  passwordHash String?
  name         String
  role                Role             @default(STUDENT)
  subscriptionTier    SubscriptionTier @default(FREE)
  subscriptionEndsAt  DateTime?
  classId             String?
  avatarConfig        Json             @default("{\"colorMode\":true,\"bodyType\":\"male\",\"body\":\"body_01.png\",\"pupils\":\"pupils_01.png\",\"eyebrows\":\"eyebrows_01.png\",\"eyelashes\":\"eyelashes_01.png\",\"mouth\":null,\"beard\":null,\"hairBack\":null,\"hair\":\"hair_01.png\",\"bangs\":null,\"hairBonus\":null,\"top\":\"top_01.png\",\"bottom\":\"bottom_01.png\",\"dress\":null,\"gloves\":null,\"shoes\":\"shoes_01.png\",\"fantasyOutfitId\":null}")
  createdAt           DateTime         @default(now())

  class        Class?    @relation(fields: [classId], references: [id], onDelete: Cascade)
  jobsHeld     JobAssignment[]
  transactions Transaction[]

  children     ParentStudentLink[] @relation("ParentToChildren")
  parents      ParentStudentLink[] @relation("ChildToParents")

  teacherOrders SupplyOrder[]

  @@index([classId])
}

model ParentStudentLink {
  parentId  String
  studentId String
  parent    User   @relation("ParentToChildren", fields: [parentId], references: [id], onDelete: Cascade)
  student   User   @relation("ChildToParents", fields: [studentId], references: [id], onDelete: Cascade)

  @@id([parentId, studentId])
}

model Class {
  id        String   @id @default(cuid())
  name      String
  joinCode  String   @unique
  createdAt DateTime @default(now())

  users     User[]
  jobs      ClassJob[]
  items     StoreItem[]
}

model ClassJob {
  id           String  @id @default(cuid())
  classId      String
  title        String
  description  String?
  weeklySalary Int
  maxOpenings  Int     @default(1)

  class       Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  assignments JobAssignment[]

  @@index([classId])
}

model JobAssignment {
  id         String   @id @default(cuid())
  jobId      String
  studentId  String
  assignedAt DateTime @default(now())

  job     ClassJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  student User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([jobId, studentId])
}

model StoreItem {
  id          String   @id @default(cuid())
  classId     String
  name        String
  description String?
  price       Int
  stock       Int
  createdAt   DateTime @default(now())

  class     Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  purchases Transaction[]

  @@index([classId])
}

model Transaction {
  id          String          @id @default(cuid())
  studentId   String
  amount      Int
  type        TransactionType
  description String?
  itemId      String?
  createdAt   DateTime        @default(now())

  student   User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  storeItem StoreItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([studentId])
}

model SupplyItem {
  id           String  @id @default(cuid())
  title        String
  description  String
  priceCents   Int
  imageUrl     String?
  affiliateUrl String?
  orderItems   OrderLineItem[]
}

model SupplyOrder {
  id         String      @id @default(cuid())
  teacherId  String
  totalCents Int
  status     OrderStatus @default(PENDING)
  createdAt  DateTime    @default(now())

  teacher User            @relation(fields: [teacherId], references: [id])
  items   OrderLineItem[]
}

model OrderLineItem {
  id           String @id @default(cuid())
  orderId      String
  supplyItemId String
  quantity     Int

  order      SupplyOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  supplyItem SupplyItem  @relation(fields: [supplyItemId], references: [id])
}
